#!/usr/bin/bash

# YOU"RE OUT OF TOUHVC

if [[ "$(date +%a)" == "Thu" ]] ; then
  if [[ ! -e /tmp/thursdayd ]] ; then
    touch /tmp/thursdayd
    # oops.
    ~/bin/allume set 20
    # YOUR:ER OUT OF TIME
    i3-msg workspace number "69:IT'S OUT OF TOUCH THURSDAY"
    # UBT iM OUT OF MY HEAD WHEN UR NOT AROUnD
    cvlc misc/thursday.mp4 --no-loop --no-repeat --no-video-title-show --mouse-hide-timeout 1 &
    sleep 30
    pkill vlc #idk why i hafta, cvlc should properly exit :<
    rm /tmp/thursdayd # i just don't want it to trigger mid trigger. i can get thursdayd repeatedly
    #oooo
    # i3-msg workspace number "69:IT'S OUT OF TOUCH THURSDAY"
    # OOoOOOoO OOOO
  fi
fi
